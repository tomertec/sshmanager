<ui:FluentWindow x:Class="SshManager.App.Views.Dialogs.OnePasswordBrowserDialog"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                xmlns:converters="clr-namespace:SshManager.App.Converters"
                mc:Ignorable="d"
                Title="Browse 1Password"
                Height="550" Width="600"
                MinHeight="400" MinWidth="500"
                WindowStartupLocation="CenterOwner"
                ExtendsContentIntoTitleBar="True"
                WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Browse 1Password"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24,8,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Vault Selector + Search -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Vault"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Vaults}"
                              SelectedItem="{Binding SelectedVault}"
                              DisplayMemberPath="Name" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Search"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    x:Name="SearchTextBox"
                                    Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Filter items..."
                                    KeyDown="SearchTextBox_KeyDown"
                                    Margin="0,0,4,0" />
                        <ui:Button Grid.Column="1"
                                   Icon="{ui:SymbolIcon Search16}"
                                   Command="{Binding SearchCommand}"
                                   Width="32" Height="32" Padding="0" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Items List -->
            <TextBlock Grid.Row="1" Text="Items"
                       FontWeight="SemiBold"
                       Margin="0,8,0,4" />

            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedItem}"
                     Margin="0,0,0,8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,2">
                            <ui:SymbolIcon Symbol="Key24" FontSize="14" Margin="0,0,8,0"
                                           VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                <TextBlock FontSize="11" Opacity="0.5"
                                           TextTrimming="CharacterEllipsis" MaxWidth="350">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Category}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Url, Converter={StaticResource NullToBoolConverter}}" Value="True">
                                                    <Setter Property="Text" Value="{Binding Url}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Fields List (visible when an item is selected) -->
            <StackPanel Grid.Row="3" Margin="0,0,0,8">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedItem, Converter={StaticResource NullToBoolConverter}}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Fields"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <ListBox ItemsSource="{Binding Fields}"
                         SelectedItem="{Binding SelectedField}"
                         MaxHeight="120">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                           MinWidth="120" />
                                <TextBlock Text="{Binding Reference}" Opacity="0.6"
                                           FontFamily="Consolas" FontSize="11" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Status -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,4,0,0">
                <ui:ProgressRing IsIndeterminate="True"
                                 Width="16" Height="16"
                                 Margin="0,0,8,0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Text="{Binding StatusText}"
                           FontSize="11" Opacity="0.6"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" Margin="24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="1"
                       Content="Cancel"
                       Command="{Binding CancelCommand}"
                       Margin="0,0,8,0"
                       MinWidth="80" />

            <ui:Button Grid.Column="2"
                       Content="Select"
                       Appearance="Primary"
                       Command="{Binding SelectFieldCommand}"
                       IsEnabled="{Binding SelectedField, Converter={StaticResource NullToBoolConverter}}"
                       MinWidth="80" />
        </Grid>
    </Grid>
</ui:FluentWindow>
