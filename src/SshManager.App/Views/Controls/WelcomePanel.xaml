<UserControl x:Class="SshManager.App.Views.Controls.WelcomePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600">

    <StackPanel VerticalAlignment="Center"
               HorizontalAlignment="Center">
        <!-- Centered Illustrated Circle with animated ring -->
        <Grid HorizontalAlignment="Center"
              Margin="0,0,0,24"
              Width="120" Height="120">

            <!-- Layer 1: Outer breathing pulse ring -->
            <Ellipse x:Name="PulseRing"
                     Width="120" Height="120"
                     StrokeThickness="1"
                     Opacity="0"
                     IsHitTestVisible="False">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="{StaticResource AccentBlue}" />
                </Ellipse.Stroke>
                <Ellipse.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" CenterX="60" CenterY="60" />
                </Ellipse.RenderTransform>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <!-- Expand outward -->
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 From="0.85" To="1.15" Duration="0:0:2.5">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 From="0.85" To="1.15" Duration="0:0:2.5">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <!-- Fade in then out -->
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                    <EasingDoubleKeyFrame KeyTime="0:0:1" Value="0.4">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <SineEase EasingMode="EaseOut" />
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                    <EasingDoubleKeyFrame KeyTime="0:0:2.5" Value="0">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <SineEase EasingMode="EaseIn" />
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Layer 2: Second pulse ring (staggered for continuous effect) -->
            <Ellipse x:Name="PulseRing2"
                     Width="120" Height="120"
                     StrokeThickness="1"
                     Opacity="0"
                     IsHitTestVisible="False">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="{StaticResource AccentBlueLight}" />
                </Ellipse.Stroke>
                <Ellipse.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" CenterX="60" CenterY="60" />
                </Ellipse.RenderTransform>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" BeginTime="0:0:1.25">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 From="0.85" To="1.15" Duration="0:0:2.5">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 From="0.85" To="1.15" Duration="0:0:2.5">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                    <EasingDoubleKeyFrame KeyTime="0:0:1" Value="0.25">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <SineEase EasingMode="EaseOut" />
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                    <EasingDoubleKeyFrame KeyTime="0:0:2.5" Value="0">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <SineEase EasingMode="EaseIn" />
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Main circle -->
            <Border x:Name="QuickConnectCircle"
                    Width="100" Height="100" CornerRadius="50"
                    Background="{DynamicResource ControlSecondaryBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderThickness="1.5"
                    Cursor="Hand"
                    ToolTip="Quick Connect - Connect to any host (Ctrl+K)"
                    MouseLeftButtonDown="QuickConnectCircle_MouseLeftButtonDown"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="QuickConnectScale" ScaleX="1" ScaleY="1" />
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource AccentBlue}" Offset="0" />
                        <GradientStop Color="{StaticResource AccentBlueLight}" Offset="0.5" />
                        <GradientStop Color="{StaticResource AccentBlue}" Offset="1" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect x:Name="QuickConnectGlow" Color="{StaticResource AccentBlue}" BlurRadius="20" ShadowDepth="0" Opacity="0.25" />
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                        To="1.08" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                        To="1.08" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                        To="40" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                        To="0.6" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                        To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                        To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                        To="20" Duration="0:0:0.3" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                        To="0.25" Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <!-- Breathing glow pulse (always running) -->
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                         From="18" To="28" Duration="0:0:2" AutoReverse="True">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                         From="0.2" To="0.4" Duration="0:0:2" AutoReverse="True">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ui:SymbolIcon Symbol="PlugConnected24"
                              FontSize="48"
                              Opacity="0.8"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
            </Border>
        </Grid>

        <TextBlock Text="Welcome to SSH Manager"
                  Style="{StaticResource DisplayText}"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,8" />
        <TextBlock Text="Select a host from the list and click Connect to start a session"
                  Style="{StaticResource BodyText}"
                  Foreground="{DynamicResource TextSecondaryBrush}"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,24" />

        <!-- Action Buttons -->
        <StackPanel Orientation="Horizontal"
                   HorizontalAlignment="Center">
            <ui:Button Command="{Binding HostManagement.AddHostCommand}"
                       Appearance="Primary"
                       CornerRadius="8"
                       Padding="16,10"
                       FontSize="{StaticResource TypeBodyLarge}"
                       Margin="0,0,12,0"
                       Cursor="Hand">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Add24" />
                </ui:Button.Icon>
                <ui:Button.Content>
                    <TextBlock x:Name="AddHostButtonText" Text="Add Host" />
                </ui:Button.Content>
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HostManagement.HasHosts}" Value="False">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <TextBlock Text="Add Your First Host" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>
            <ui:DropDownButton Icon="{ui:SymbolIcon ArrowDownload24}"
                              Content="Import Hosts"
                              Padding="16,10"
                              FontSize="{StaticResource TypeBodyLarge}"
                              CornerRadius="8">
                <ui:DropDownButton.Flyout>
                    <ContextMenu>
                        <ui:MenuItem Header="From File..."
                                    Icon="{ui:SymbolIcon Document24}"
                                    Click="ImportHostsButton_Click" />
                        <ui:MenuItem Header="From SSH Config..."
                                    Icon="{ui:SymbolIcon Code24}"
                                    Click="ImportFromSshConfigButton_Click" />
                        <ui:MenuItem Header="From PuTTY..."
                                    Icon="{ui:SymbolIcon WindowConsole20}"
                                    Click="ImportFromPuttyButton_Click" />
                    </ContextMenu>
                </ui:DropDownButton.Flyout>
            </ui:DropDownButton>
        </StackPanel>

        <!-- Quick Action Info Cards -->
        <StackPanel Orientation="Horizontal"
                   HorizontalAlignment="Center"
                   Margin="0,28,0,0">
            <!-- SSH Connections card -->
            <Border Style="{StaticResource SubtleCard}"
                    Width="160"
                    Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="Globe24"
                                  FontSize="24"
                                  HorizontalAlignment="Center"
                                  Opacity="0.7"
                                  Margin="0,0,0,8" />
                    <TextBlock Text="SSH Connections"
                              Style="{StaticResource BodyStrongText}"
                              HorizontalAlignment="Center"
                              TextAlignment="Center"
                              Margin="0,0,0,4" />
                    <TextBlock Text="Manage remote servers"
                              Style="{StaticResource CaptionText}"
                              HorizontalAlignment="Center"
                              TextAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Serial Ports card -->
            <Border Style="{StaticResource SubtleCard}"
                    Width="160"
                    Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="UsbPlug24"
                                  FontSize="24"
                                  HorizontalAlignment="Center"
                                  Opacity="0.7"
                                  Margin="0,0,0,8" />
                    <TextBlock Text="Serial Ports"
                              Style="{StaticResource BodyStrongText}"
                              HorizontalAlignment="Center"
                              TextAlignment="Center"
                              Margin="0,0,0,4" />
                    <TextBlock Text="Connect to COM devices"
                              Style="{StaticResource CaptionText}"
                              HorizontalAlignment="Center"
                              TextAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Import card -->
            <Border Style="{StaticResource SubtleCard}"
                    Width="160">
                <StackPanel HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="ArrowImport24"
                                  FontSize="24"
                                  HorizontalAlignment="Center"
                                  Opacity="0.7"
                                  Margin="0,0,0,8" />
                    <TextBlock Text="Import"
                              Style="{StaticResource BodyStrongText}"
                              HorizontalAlignment="Center"
                              TextAlignment="Center"
                              Margin="0,0,0,4" />
                    <TextBlock Text="From SSH config or PuTTY"
                              Style="{StaticResource CaptionText}"
                              HorizontalAlignment="Center"
                              TextAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Keyboard Shortcut Hint at bottom -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,28,0,0">
            <Border Style="{StaticResource KeyboardHint}" Margin="4">
                <TextBlock Text="Ctrl+K" Style="{StaticResource MonoText}" />
            </Border>
            <TextBlock Text="Quick Connect"
                      Style="{StaticResource CaptionText}"
                      VerticalAlignment="Center"
                      Margin="8,0" />
        </StackPanel>
    </StackPanel>
</UserControl>
